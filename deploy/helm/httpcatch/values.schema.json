{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "httpcatch chart values",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "image",
    "persistence",
    "service",
    "serviceAccount"
  ],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository", "pullPolicy"],
      "properties": {
        "registry":   { "type": "string" },
        "repository": { "type": "string", "minLength": 1 },
        "tag":        { "type": "string" },
        "digest":     { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "pullSecrets": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "logFormat":    { "type": "string", "enum": ["text", "json"] },
    "capturePort":  { "type": "integer", "minimum": 1, "maximum": 65535 },
    "queueSize":    { "type": "integer", "minimum": 1 },
    "bodyCap":      { "type": "integer", "minimum": 0 },
    "maxEventsPayload": { "type": "integer", "minimum": 0 },
    "workers":      { "type": "integer", "minimum": 1 },
    "serviceHeader": { "type": "string" },
    "sinks": {
      "type": "object",
      "properties": {
        "stdout":         { "type": "boolean" },
        "memory":         { "type": "boolean" },
        "memoryCapacity": { "type": "integer", "minimum": 0 }
      }
    },
    "admin": {
      "type": "object",
      "properties": {
        "sessionTTL":    { "type": "string" },
        "sessionSecure": { "type": "boolean" }
      }
    },
    "adminToken": {
      "type": "object",
      "properties": {
        "value":             { "type": "string" },
        "existingSecret":    { "type": "string" },
        "existingSecretKey": { "type": "string" }
      }
    },
    "redaction": {
      "type": "object",
      "properties": {
        "headers":     { "type": "array", "items": { "type": "string" } },
        "queryParams": { "type": "array", "items": { "type": "string" } },
        "jsonPaths":   { "type": "array", "items": { "type": "string" } },
        "regex": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "pattern"],
            "properties": {
              "name":    { "type": "string" },
              "pattern": { "type": "string" }
            }
          }
        },
        "cookies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["mode", "names"],
            "properties": {
              "mode":  { "type": "string", "enum": ["redact", "strip", "allowlist"] },
              "names": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "extraConfig": { "type": "object" },
    "persistence": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled":       { "type": "boolean" },
        "existingClaim": { "type": "string" },
        "storageClass":  { "type": "string" },
        "accessModes": {
          "type": "array",
          "items": { "type": "string", "enum": ["ReadWriteOnce", "ReadWriteOncePod", "ReadOnlyMany", "ReadWriteMany"] }
        },
        "size":      { "type": "string" },
        "mountPath": { "type": "string" },
        "retentionPolicy": {
          "type": "object",
          "properties": {
            "whenDeleted": { "type": "string", "enum": ["Retain", "Delete"] },
            "whenScaled":  { "type": "string", "enum": ["Retain", "Delete"] }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "capture": {
          "type": "object",
          "properties": {
            "type":        { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "port":        { "type": "integer", "minimum": 1, "maximum": 65535 },
            "annotations": { "type": "object" }
          }
        },
        "admin": {
          "type": "object",
          "properties": {
            "type":        { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "port":        { "type": "integer", "minimum": 1, "maximum": 65535 },
            "annotations": { "type": "object" }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled":     { "type": "boolean" },
        "className":   { "type": "string" },
        "host":        { "type": "string" },
        "path":        { "type": "string" },
        "pathType":    { "type": "string", "enum": ["Exact", "Prefix", "ImplementationSpecific"] },
        "annotations": { "type": "object" },
        "tls": {
          "type": "object",
          "properties": {
            "enabled":    { "type": "boolean" },
            "secretName": { "type": "string" }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "required": ["create"],
      "properties": {
        "create":      { "type": "boolean" },
        "name":        { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "podSecurityContext":       { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "resources":                { "type": "object" },
    "probes": {
      "type": "object",
      "properties": {
        "liveness":  { "type": "object" },
        "readiness": { "type": "object" },
        "startup":   { "type": "object" }
      }
    },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "deployment": {
      "type": "object",
      "properties": {
        "strategy": { "type": "object" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled":        { "type": "boolean" },
        "minAvailable":   { "type": ["string", "integer"] },
        "maxUnavailable": { "type": ["string", "integer"] }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled":     { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage":    { "type": ["string", "integer"] },
        "targetMemoryUtilizationPercentage": { "type": ["string", "integer"] },
        "behavior": { "type": "object" }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled":           { "type": "boolean" },
        "interval":          { "type": "string" },
        "scrapeTimeout":     { "type": "string" },
        "labels":            { "type": "object" },
        "namespace":         { "type": "string" },
        "relabelings":       { "type": "array" },
        "metricRelabelings": { "type": "array" },
        "honorLabels":       { "type": "boolean" }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations":  { "type": "array" },
    "affinity":     { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },
    "priorityClassName": { "type": "string" },
    "podAnnotations":    { "type": "object" },
    "podLabels":         { "type": "object" },
    "commonLabels":      { "type": "object" },
    "commonAnnotations": { "type": "object" },
    "extraEnv":             { "type": "array" },
    "extraEnvFrom":         { "type": "array" },
    "extraVolumes":         { "type": "array" },
    "extraVolumeMounts":    { "type": "array" },
    "extraInitContainers":  { "type": "array" },
    "extraContainers":      { "type": "array" }
  }
}
